<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Teacher Details — MySchool</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="/tdetail.css">
</head>

<body>

<div class="teacher-wrapper">

    <div class="teacher-card">

        <h2>My Details</h2>

        <!-- Static Teacher Icon Added -->
        <div style="text-align: center; margin-bottom: 20px;">
            <img src="https://cdn-icons-png.flaticon.com/512/1077/1077063.png"
                 alt="Teacher Icon"
                 width="130"
                 style="border-radius: 50%;">
        </div>

        <div class="info-box">
            <p><strong>ID:</strong> <%= teacher.id %></p>
            <p><strong>Name:</strong> <%= teacher.name %></p>
            <p><strong>Email:</strong> <%= teacher.email %></p>
            <p><strong>Password:</strong> <%= teacher.password %></p>
            <p><strong>Department:</strong> <%= teacher.department %></p>
        </div>


    </div>

</div>

</body>
</html>
