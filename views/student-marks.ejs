<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Marks — <%= student.name %></title>
  <link rel="stylesheet" href="/student-marks.css">
</head>
<body>

<div class="wrapper">
  <div class="card">
    <h2>Marks — <%= student.name %></h2>

    <div class="details-box">
      <p><strong>ID:</strong> <%= student.id %></p>
      <p><strong>Department:</strong> <%= student.department %></p>
      <p><strong>Courses:</strong> <%= student.courses %></p>
    </div>

    <h3 style="margin-top:16px;">Marks</h3>

    <table class="styled-table">
      <thead>
        <tr>
          <th>Subject</th>
          <th>Marks</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody>
        <% marks.forEach(m => { %>
        <tr>
          <td><%= m.subject %></td>
          <td><%= m.marks %></td>

          <td>
            <!-- EDIT -->
            <a href="/edit-marks/<%= student.id %>/<%= m.id %>?email=<%= teacherEmail %>" 
               class="btn-edit">
               Edit
            </a>

            <!-- DELETE -->
            <form action="/delete-marks/<%= student.id %>/<%= m.id %>?email=<%= teacherEmail %>"
                  method="POST"
                  style="display:inline-block;"
                  onsubmit="return confirm('Delete this marks entry?');">

              <input type="hidden" name="teacherEmail" value="<%= teacherEmail %>">

              <button class="btn-delete" type="submit">Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <div style="margin-top:16px;">
      <a href="/teacher-login?email=<%= teacherEmail %>" class="btn-back">
        Back
      </a>
    </div>

  </div>
</div>

</body>
</html>
