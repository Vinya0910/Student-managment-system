<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard — MySchool</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="/admin.css">
</head>
<body>

<div class="dashboard-container">
    <h1 class="title">Welcome, <%= admin.email %></h1>

    <!-- Static Admin Icon -->
    <div class="admin-image" style="text-align: center; margin-bottom: 20px;">
        <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
             alt="Admin Icon"
             width="120"
             style="border-radius: 50%;">
    </div>

    <!-- TOP ACTION BUTTONS -->
    <div class="top-actions">
        <a href="/add-student" class="btn-primary">Add New Student</a>
        <a href="/teachers" class="btn-secondary">View Teachers</a>
        <a href="/admin-dashboard" class="btn-analytics">View Analytics</a>
    </div>

    <div class="card">
        <h2>All Students</h2>

        <div class="table-wrapper">
            <table class="styled-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Password</th>
                        <th>Department</th>
                        <th>Courses</th>     <!-- ⭐ NEW COLUMN -->
                        <th>Edit</th>
                        <th>View</th>
                    </tr>
                </thead>

                <tbody>
                    <% students.forEach(s => { %>
                    <tr>
                        <td><%= s.id %></td>
                        <td><%= s.name %></td>
                        <td><%= s.email %></td>
                        <td><%= s.password %></td>
                        <td><%= s.department %></td>

                        <!-- ⭐ NEW COURSE COLUMN -->
                        <td><%= s.courses %></td>

                        <td>
                            <a class="btn-link edit" href="/edit/<%= s.id %>">Edit</a>
                        </td>
                        <td>
                            <a class="btn-link view" href="/view/<%= s.id %>">View</a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>

            </table>
        </div>
    </div>

</div>

</body>
</html>
