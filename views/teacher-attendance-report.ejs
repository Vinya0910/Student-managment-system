<!DOCTYPE html>
<html>
<head>
    <title>Attendance Report</title>
    <link rel="stylesheet" href="/report.css">
</head>
<body>

<div class="container">

    <h2 class="title">Attendance Report</h2>

    <table class="styled-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Date</th>
                <th>Status</th>
            </tr>
        </thead>

        <tbody>
            <% records.forEach(r => { %>
            <tr>
                <td><%= r.name %></td>
                <td><%= r.date.toISOString().slice(0,10) %></td>
                <td class="<%= r.status === 'Present' ? 'present' : 'absent' %>">
                    <%= r.status %>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>

</div>

</body>
</html>
