<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Add Marks — MySchool</title>
  <link rel="stylesheet" href="/add-marks.css">
</head>
<body>

<div class="wrapper">
  <div class="card">
    <h2>Add Marks for <%= student.name %></h2>

    <% const subjects = student.courses ? student.courses.split(",").map(s => s.trim()) : []; %>

    <% if (subjects.length === 0) { %>
      <p>No courses available for this student.</p>
    <% } else { %>

    <!-- IMPORTANT: attach ?email=teacherEmail -->
    <form action="/add-marks/<%= student.id %>?email=<%= teacherEmail %>" method="POST">

      <input type="hidden" name="teacherEmail" value="<%= teacherEmail %>">

      <div class="form-group">
        <label>Select Subject</label>
        <select name="subject" required>
          <% subjects.forEach(sub => { %>
            <option><%= sub %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Marks (0–100)</label>
        <input type="number" name="marks" required min="0" max="100">
      </div>

      <button class="btn-save" type="submit">Submit</button>
    </form>

    <% } %>

    <!-- FIXED BACK BUTTON -->
    <a href="/teacher-login?email=<%= teacherEmail %>" class="btn-back">Back</a>

  </div>
</div>

</body>
</html>
